+void apl_metadata_json_string( std::ostream& out, std::string_view value )
+{
+  out << '"';
+  for ( const char c : value )
+  {
+    if ( c == '\\' || c == '"' ) out << '\\';
+    out << c;
+  }
+  out << '"';
+}
+
+void export_apl_metadata( const sim_t& sim )
+{
+  const bool valid_revision = sim.apl_metadata_revision.size() == 40 &&
+    std::all_of( sim.apl_metadata_revision.begin(), sim.apl_metadata_revision.end(),
+                 []( unsigned char c ) { return std::isxdigit( c ); } );
+  if ( !valid_revision )
+    throw std::runtime_error( "apl_metadata_revision must be a 40-character hexadecimal git SHA" );
+  std::ofstream out( sim.apl_metadata_export_file );
+  if ( !out ) throw std::runtime_error( "Unable to open APL metadata export file" );
+  out << "{\"schema_version\":1,\"simc_revision\":";
+  apl_metadata_json_string( out, sim.apl_metadata_revision );
+  out << ",\"game_build\":";
+  apl_metadata_json_string( out, sim.apl_metadata_game_build );
+  out << R"json(,"generated_at":null,"completeness":{"status":"partial","modules":{"global":"runtime_initialized"},"limitations":["Dynamic action factories and spell IDs are not exhaustively enumerable without initialized actor profiles."]},"symbols":[)json";
+  bool first = true;
+  std::set<std::string> option_names;
+  for ( const auto& option : sim.options ) option_names.insert( std::string( option->name() ) );
+  for ( const auto& name : option_names )
+  {
+    if ( !first ) out << ',';
+    first = false;
+    out << "{\"class\":null,\"spec\":null,\"scope\":\"global\",\"token\":";
+    apl_metadata_json_string( out, name );
+    out << ",\"kind\":\"option\",\"spell_id\":null,\"source\":\"runtime_option\",\"options\":[],\"aliases\":[]}";
+  }
+  out << "]}\n";
+}
+
