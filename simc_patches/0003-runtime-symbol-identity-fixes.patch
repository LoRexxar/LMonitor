+void upsert_apl_metadata_symbol( std::set<apl_metadata_symbol_t>& symbols, apl_metadata_symbol_t symbol )
+{
+  auto existing = symbols.find( symbol );
+  if ( existing == symbols.end() )
+  {
+    symbols.insert( std::move( symbol ) );
+    return;
+  }
+
+  apl_metadata_symbol_t merged = *existing;
+  symbols.erase( existing );
+  merged.candidates.insert( symbol.candidates.begin(), symbol.candidates.end() );
+  if ( merged.spell_id ) merged.candidates.insert( merged.spell_id );
+  if ( symbol.spell_id ) merged.candidates.insert( symbol.spell_id );
+  if ( merged.trait_node_id ) merged.trait_node_candidates.insert( merged.trait_node_id );
+  if ( symbol.trait_node_id ) merged.trait_node_candidates.insert( symbol.trait_node_id );
+  merged.options.insert( symbol.options.begin(), symbol.options.end() );
+  merged.hero_talent = merged.hero_talent || symbol.hero_talent;
+
+  if ( merged.trait_node_candidates.size() == 1 )
+  {
+    merged.trait_node_id = *merged.trait_node_candidates.begin();
+  }
+  else if ( merged.trait_node_candidates.size() > 1 )
+  {
+    merged.trait_node_id = 0;
+    merged.reason = "ambiguous_trait_node_identity";
+  }
+
+  if ( merged.candidates.size() == 1 )
+  {
+    merged.spell_id = *merged.candidates.begin();
+    if ( merged.trait_node_id || merged.kind != "talent" ) merged.reason.clear();
+  }
+  else if ( merged.candidates.size() > 1 )
+  {
+    merged.spell_id = 0;
+    merged.reason = "ambiguous_spell_identity";
+  }
+  else if ( merged.reason.empty() && !symbol.reason.empty() )
+  {
+    merged.reason = std::move( symbol.reason );
+  }
+
+  if ( merged.source.empty() || ( !symbol.source.empty() && symbol.spell_id ) )
+    merged.source = std::move( symbol.source );
+  symbols.insert( std::move( merged ) );
+}
